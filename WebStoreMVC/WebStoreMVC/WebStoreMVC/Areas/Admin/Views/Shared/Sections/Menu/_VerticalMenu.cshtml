@{
    TempData.Keep();
    string? currentPage = ViewContext.HttpContext.Request.Path;
}

<!-- Menu -->
@* ! Do this simple *@
<aside id="layout-menu" class="layout-menu menu-vertical menu">

    @* ! Hide app brand if navbar-full *@
    <div class='px-6 py-5 @((ViewData["navbarFull"] != null && Convert.ToBoolean(ViewData["navbarFull"])) ? "d-xl-none" : "")'>
        <a asp-area=""
           asp-controller="Home"
           asp-action="Index"
           class="app-brand-link d-flex justify-content-center justify-content-lg-start align-items-center">

            <img src="~/admin/img/College.svg"
                 alt="College Logo"
                 class="img-fluid"
                 style="max-height: 50px; width: auto;">
        </a>
    </div>

    <div class="menu-inner-shadow"></div>

    @* ! Full version menu-items *@
    <ul class="menu-inner py-1">

        <!-- Products -->
        <li class='menu-item@(currentPage.StartsWith("/admin") ? " active open" : "")'>
            <a href="javascript:void(0);" class="menu-link menu-toggle">
                <i class="menu-icon tf-icons ri-box-3-line"></i>
                <div>Продукти</div>
            </a>
            <ul class="menu-sub">
                <li class='menu-item@(currentPage == "/admin" ? " active" : "")'>
                    <a asp-controller="Products" asp-action="Index" class="menu-link">
                        <div>Перегляд</div>
                    </a>
                </li>
                <li class='menu-item@(currentPage == "/admin/Products/Create" ? " active" : "")'>
                    <a asp-controller="Products" asp-action="Create" class="menu-link">
                        <div>Додати</div>
                    </a>
                </li>
            </ul>
        </li>

    </ul>

</aside>
<!-- / Menu -->
