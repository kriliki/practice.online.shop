@model WebStoreMVC.Models.Account.ProfileViewModel

<h1 class="text-center mb-4">
    Особистий кабінет
</h1>

<div class="row">

    <div class="col-md-4">

        <div class="card">

            <div class="card-body text-center">

                <img src="/images/200_@(Model.Image ?? "no-image.webp")"
                     class="rounded-circle mb-3"
                     width="180">

                <h4>
                    @Model.FirstName @Model.LastName
                </h4>

                <p class="text-muted">
                    @Model.Email
                </p>

            </div>

        </div>

    </div>

    <div class="col-md-8">

        <div class="card">

            <div class="card-header">
                Меню
            </div>

            <div class="card-body">

                <div class="d-grid gap-3">

                    <a asp-controller="Orders"
                       asp-action="Index"
                       class="btn btn-primary">

                        Мої замовлення (@Model.OrdersCount)

                    </a>

                    <a asp-controller="Account"
                       asp-action="EditProfile"
                       class="btn btn-outline-secondary">

                        Редагувати профіль

                    </a>

                    <form asp-controller="Account"
                          asp-action="Logout"
                          method="post">

                        <button class="btn btn-danger w-100">
                            Вихід
                        </button>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>