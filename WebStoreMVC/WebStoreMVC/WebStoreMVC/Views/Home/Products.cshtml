@using System.Text.RegularExpressions
@model IEnumerable<WebStoreMVC.Models.Product.ProductItemModel>

@{
    ViewData["Title"] = "Каталог товарів";
}

<div class="container py-2">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-controller="Home" asp-action="Index">Головна</a>
            </li>
            <li class="breadcrumb-item active">
                Продукти по категорії
            </li>
        </ol>
    </nav>

    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Каталог товарів @ViewBag.CategoryName</h1>
        <p class="text-muted">
            Оберіть товар для перегляду
        </p>
    </div>

    <div class="row g-4">
        @foreach (var product in Model)
        {
            var image = product.Images.FirstOrDefault() ?? "no-image.webp";

            <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                <div class="card h-100 shadow-sm border-0 product-card">

                    <img src="@($"/images/400_{image}")"
                         class="card-img-top"
                         alt="@product.Name"
                         style="height: 250px; object-fit: cover;" />

                    <div class="card-body d-flex flex-column">

                        <h5 class="card-title fw-semibold">
                            @product.Name
                        </h5>

                        <p class="text-muted small">
                            @product.CategoryName
                        </p>

                        <p class="card-text">
                            @Html.Raw(
                                product.Description != null
                                    ? Regex.Replace(product.Description, "<.*?>", "").Substring(0, Math.Min(100, Regex.Replace(product.Description, "<.*?>", "").Length)) + "..."
                                : ""
                            )
                        </p>

                        <div class="mt-auto">
                            <h4 class="text-primary fw-bold mb-3">
                                @product.Price.ToString("0.00") грн
                            </h4>

                            <a asp-controller="Products"
                               asp-action="Details"
                               asp-route-slug="@product.Slug"
                               class="btn btn-primary w-100 stretched-link">
                                Детальніше
                            </a>
                        </div>

                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .product-card {
        transition: all .3s ease;
        border-radius: 16px;
        overflow: hidden;
    }

        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,.15);
        }

    .card-img-top {
        transition: transform .3s ease;
    }

    .product-card:hover .card-img-top {
        transform: scale(1.05);
    }
</style>