@model List<WebStoreMVC.Models.Order.OrderListItemModel>

<div class="container py-2">
    <h1 class="display-4 fw-bold text-center mb-5">Мої замовлення</h1>

    <table class="table">
        <thead>
            <tr>
                <th>№</th>
                <th>Дата</th>
                <th>Сума</th>
                <th>Статус</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model)
            {
                <tr>
                    <td>@order.Id</td>
                    <td>@order.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@order.TotalAmount грн</td>
                    <td>@order.OrderStatusName</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-primary">Деталі</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>